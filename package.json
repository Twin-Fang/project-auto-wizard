  "repository": {
    "type": "git",
    "url": "git+https://github.com/Twin-Fang/project-auto-wizard.git"
  },
  "keywords": [
    "devops",
    "automation",
    "github-actions",
    "cli",
    "release-automation",
    "changelog",
    "wizard"
  ]
