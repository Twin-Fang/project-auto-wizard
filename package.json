{
  "name": "project-auto-wizard",
  "version": "0.1.3",
  "description": "One command DevOps: npx wizard that installs GitHub-native AI Release Automation into any project",
  "license": "MIT",
  "type": "module",
  "bin": {
    "project-auto-wizard": "bin/project-auto-wizard.js"
  },
  "engines": {
    "node": ">=20.12"
  },
  "files": [
    "bin/",
    "src/",
    "payload/"
